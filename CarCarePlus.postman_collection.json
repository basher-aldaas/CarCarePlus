{
	"info": {
		"_postman_id": "b1a7c0de-carcareplus-0001-0001-000000000001",
		"name": "CarCarePlus API",
		"description": "Auth, registration and super-admin approval endpoints for CarCarePlus.\n\nSet the `base_url` variable (default http://localhost:8000). The Login / Register Customer requests automatically save the returned Sanctum token into the `token` collection variable, which every authenticated request uses as a Bearer token.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register Customer (Type 1)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"const token = res?.data?.token;",
									"if (token) { pm.collectionVariables.set('token', token); console.log('token saved'); }"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Customer\",\n    \"email\": \"customer@example.com\",\n    \"phone\": \"0500000001\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"is_active\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register/customer",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "register", "customer" ]
						},
						"description": "Personal customer self-registration. Active immediately and returns a token.\n\nNote: `image_url` is an optional image upload (jpg/jpeg/png/webp, max 2MB) — use form-data if you want to send it."
					}
				},
				{
					"name": "Register Company (Type 2a)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Company Owner\",\n    \"email\": \"company@example.com\",\n    \"phone\": \"0500000002\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"is_active\": false,\n    \"company_name\": \"Acme Auto\",\n    \"company_name_ar\": \"أكمي أوتو\",\n    \"commercial_reg\": \"CR-123456\",\n    \"tax_number\": \"TAX-123456\",\n    \"company_address\": \"123 King Fahd Rd, Riyadh\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register/company",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "register", "company" ]
						},
						"description": "Company customer submits a registration request. Pending super-admin approval (no token issued)."
					}
				},
				{
					"name": "Register Workshop (Type 2b)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Workshop Owner\",\n    \"email\": \"workshop@example.com\",\n    \"phone\": \"0500000003\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"is_active\": false,\n    \"workshop_name\": \"Speedy Garage\",\n    \"workshop_name_ar\": \"الكراج السريع\",\n    \"workshop_address\": \"45 Olaya St, Riyadh\",\n    \"workshop_city\": \"Riyadh\",\n    \"latitude\": 24.7136,\n    \"longitude\": 46.6753\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register/workshop",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "register", "workshop" ]
						},
						"description": "Workshop submits a registration request. Pending super-admin approval (no token issued)."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"const token = res?.data?.token;",
									"if (token) { pm.collectionVariables.set('token', token); console.log('token saved'); }"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"customer@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "login" ]
						},
						"description": "Log in and receive a Sanctum token. The token is saved to the `token` collection variable automatically."
					}
				},
				{
					"name": "Logout",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/auth/logout",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "logout" ]
						},
						"description": "Revoke the current access token. Requires auth:sanctum."
					}
				},
				{
					"name": "Get Authenticated User",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/user",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "user" ]
						},
						"description": "Return the currently authenticated user. Requires auth:sanctum."
					}
				}
			]
		},
		{
			"name": "Password",
			"item": [
				{
					"name": "Forgot Password (link)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"customer@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/forgot-password",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "forgot-password" ]
						},
						"description": "Send a password reset link by email. Always responds generically to prevent account enumeration."
					}
				},
				{
					"name": "Reset Password (link token)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"token\": \"PASTE_TOKEN_FROM_EMAIL\",\n    \"email\": \"customer@example.com\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/reset-password",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "reset-password" ]
						},
						"description": "Set a new password using the token from the reset email."
					}
				},
				{
					"name": "Send Reset OTP",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"customer@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/password/otp/send",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "password", "otp", "send" ]
						},
						"description": "Email a one-time reset code. Responds generically to prevent account enumeration."
					}
				},
				{
					"name": "Reset Password (OTP)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"customer@example.com\",\n    \"otp\": \"123456\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/password/otp/reset",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "password", "otp", "reset" ]
						},
						"description": "Set a new password using the emailed OTP code."
					}
				},
				{
					"name": "Change Password",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"current_password\": \"password123\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/change-password",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "change-password" ]
						},
						"description": "Change the password for the authenticated user. Requires auth:sanctum."
					}
				}
			]
		},
		{
			"name": "Admin (Super Admin)",
			"description": "All endpoints require auth:sanctum and the super_admin role.",
			"item": [
				{
					"name": "Create Employee (Type 3)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Ali Employee\",\n    \"email\": \"employee@example.com\",\n    \"phone\": \"0500000004\",\n    \"password\": \"password123\",\n    \"branch_id\": 1,\n    \"type\": \"mechanic\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/admin/employees",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "employees" ]
						},
						"description": "Super admin creates an employee. `type` is one of: washer, mechanic."
					}
				},
				{
					"name": "Create Admin (Branch Admin)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Branch Admin\",\n    \"email\": \"branchadmin@example.com\",\n    \"phone\": \"0500000005\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"is_active\": true,\n    \"branch_id\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/admin/admins",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "admins" ]
						},
						"description": "Super admin creates a branch admin account."
					}
				},
				{
					"name": "List Pending Company Requests",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/admin/registration-requests/companies",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "registration-requests", "companies" ]
						}
					}
				},
				{
					"name": "List Pending Workshop Requests",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/admin/registration-requests/workshops",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "registration-requests", "workshops" ]
						}
					}
				},
				{
					"name": "Approve Company",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/admin/registration-requests/companies/:company/approve",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "registration-requests", "companies", ":company", "approve" ],
							"variable": [ { "key": "company", "value": "1", "description": "Company ID" } ]
						}
					}
				},
				{
					"name": "Reject Company",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"reason\": \"Incomplete commercial registration documents\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/admin/registration-requests/companies/:company/reject",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "registration-requests", "companies", ":company", "reject" ],
							"variable": [ { "key": "company", "value": "1", "description": "Company ID" } ]
						}
					}
				},
				{
					"name": "Approve Workshop",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/admin/registration-requests/workshops/:workshop/approve",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "registration-requests", "workshops", ":workshop", "approve" ],
							"variable": [ { "key": "workshop", "value": "1", "description": "Workshop ID" } ]
						}
					}
				},
				{
					"name": "Reject Workshop",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
						},
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"reason\": \"Location could not be verified\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/admin/registration-requests/workshops/:workshop/reject",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "admin", "registration-requests", "workshops", ":workshop", "reject" ],
							"variable": [ { "key": "workshop", "value": "1", "description": "Workshop ID" } ]
						}
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000" },
		{ "key": "token", "value": "" }
	]
}
